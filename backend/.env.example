# ============================================================
# GMS Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# Local dev: postgres runs on host port 5433 (docker-compose remapped from 5432)
# In Docker network (Phase 25): use postgresql://postgres:password@postgres:5432/gms_db
DATABASE_URL=postgresql://postgres:password@localhost:5433/gms_db

# --- Security ---
# Generate a strong random key, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Redis / Celery (Phase 17+) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Interval (seconds) for the SLA breach sweep task
SLA_SWEEP_SECONDS=300

# --- Email / SMTP (Phase 20+) ---
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@yourdomain.com
MAIL_PORT=587
MAIL_SERVER=smtp.yourdomain.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
# Set to True in dev/staging to log emails without actually sending them
MAIL_SUPPRESS_SEND=True
