# ============================================================
# GMS Frontend — Vite Environment Variables
# Copy this file to .env and fill in the values.
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# NEVER commit .env to version control.
# ============================================================

# --- API Base URL ---
# Dev: points at the local FastAPI server (port 4010).
# Production / Docker: use "/api/v1" (relative) when Nginx proxies /api → backend.
VITE_API_BASE=http://localhost:4010/api/v1

# --- App Meta ---
VITE_APP_NAME=Grievance Management System
